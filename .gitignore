# Claude generated gitignore I am using before beginning with these tools
# =========================
# Terraform
# =========================
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfplan

# =========================
# Ansible
# =========================
*.retry
.vault_pass
vault_password_file
ansible/inventory/hosts          # if auto-generated by Terraform output

# =========================
# AWS / Credentials
# =========================
*.pem
.env
.envrc
credentials

# =========================
# macOS
# =========================
.DS_Store
.AppleDouble
.LSOverride
._*

# =========================
# Editor
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Misc
# =========================
*.log
*.tmp
*.bak
*.dwo
